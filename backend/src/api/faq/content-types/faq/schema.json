{
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "question": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "answer": { "type": "richtext", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "order": { "type": "integer" },
    "page": {
      "type": "enumeration",
      "enum": ["homepage", "namecard", "both"],
      "default": "homepage"
    }
  }
}
